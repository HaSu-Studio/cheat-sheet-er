# Docker Compose подхватывает этот файл автоматически (лежит рядом с docker-compose.yml)
COMPOSE_PROJECT_NAME=notareon-frontend

FRONTEND_IMAGE=notareon/frontend:local
FRONTEND_PORT=5173

# URL API с точки зрения браузера (должен совпадать с notareon-server: API_PORT)
VITE_API_URL=http://localhost:3000

# Для npm run dev (Vite) без Docker — те же переменные можно продублировать в .env
